{
    "manifest_version": 3,
    "name": "K-ROOM YT Music Control",
    "version": "1.0.0",
    "description": "Stabilize YouTube Music volume with a professional compressor and limiter. Zero distortion.",
    "permissions": [
        "storage"
    ],
    "icons": {
        "16": "icons/icon.png",
        "32": "icons/icon.png",
        "48": "icons/icon.png",
        "128": "icons/icon.png"
    },
    "content_scripts": [
        {
            "matches": [
                "*://music.youtube.com/*"
            ],
            "js": [
                "src/scripts/presets.js",
                "src/scripts/audio_engine.js",
                "src/scripts/content_script.js"
            ],
            "run_at": "document_idle",
            "all_frames": false
        }
    ],
    "action": {
        "default_popup": "src/popup/popup.html",
        "default_title": "K-ROOM YT Music Control",
        "default_icon": {
            "16": "icons/icon.png",
            "32": "icons/icon.png",
            "48": "icons/icon.png",
            "128": "icons/icon.png"
        }
    }
}